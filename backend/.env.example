# ─────────────────────────────────────────────────────────
# Backend environment variables
# Copy to .env and fill in values for local development.
# On Railway, set these as service Variables in the dashboard.
# ─────────────────────────────────────────────────────────

# OpenAI API key for AI advisor and insights features
OPENAI_API_KEY=sk-...

# SQLite database path (for Railway: use the Volume mount path)
# Example for Railway: sqlite:////app/data/dev.db
# Local default (leave blank): sqlite:///./dev.db
DATABASE_URL=

# CORS: comma-separated list of allowed frontend origins
# Example: https://my-frontend.up.railway.app
# Set to * to allow all origins (acceptable for thesis demo)
ALLOWED_ORIGINS=*
