# ─────────────────────────────────────────────────────────
# Frontend environment variables
# Copy to .env and fill in values for local development.
# On Railway, set these as service Variables in the dashboard.
# ─────────────────────────────────────────────────────────

# URL of the deployed backend (Railway will give you this after deploying the backend service).
# Example: https://backend-production-abc123.up.railway.app
# Leave blank for local dev (falls back to http://127.0.0.1:8000)
VITE_API_URL=

# Password required to access the application.
# Leave blank to disable the password gate entirely (local dev).
# Example: VITE_APP_PASSWORD=thesis2025
VITE_APP_PASSWORD=
